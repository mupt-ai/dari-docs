# Local managed-service env. Copy to .env.local for direct local service runs,
# or copy .env.example to .env for `docker compose up`.

# --- Local service ---
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DARI_API_BASE_URL=https://dev-api.dari.dev
DATABASE_URL=postgres://dari_docs:dari_docs@localhost:5432/dari_docs_local?sslmode=disable

# --- Supabase (required for sign-in) ---
SUPABASE_URL=https://yfvkbiteydpnffwozqhe.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_7jjhnXR4l2hBJKyCQkGs3g_Tb0AR71p

# --- Hosted Dari agents (required for real managed runs) ---
DARI_API_KEY=
MANAGED_TESTER_AGENT_ID=
MANAGED_TESTER_VERSION_ID=
MANAGED_EDITOR_AGENT_ID=
MANAGED_EDITOR_VERSION_ID=

# --- Service secrets (required outside placeholder local development) ---
DARI_DOCS_RELEASE_ADMIN_TOKEN=
DARI_DOCS_SECRET_ENCRYPTION_KEY=

# --- Docker Compose host ports (optional) ---
# Leave these blank or unset to let Docker choose open localhost ports.
API_HOST_PORT=
WEB_HOST_PORT=
POSTGRES_HOST_PORT=

# --- Vite (optional) ---
# Comma-separated hostnames allowed by the Vite dev server.
# VITE_ALLOWED_HOSTS=

# --- Optional locally unless you want to test checkout/webhooks. ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
