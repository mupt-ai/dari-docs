# Local managed-service env. Copy to .env.local and fill in secret values.

PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DARI_API_BASE_URL=https://api.dari.dev

DATABASE_URL=postgres://dari_docs:dari_docs@localhost:5432/dari_docs_local?sslmode=disable
DARI_API_KEY=
MANAGED_TESTER_AGENT_ID=
MANAGED_EDITOR_AGENT_ID=
DARI_DOCS_RELEASE_ADMIN_TOKEN=
DARI_DOCS_SECRET_ENCRYPTION_KEY=

# Optional locally unless you want to test checkout/webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
