# Copy to .env at the repo root for `docker compose up`.
# Variables flow into the managed-service backend and Vite frontend.

# --- Supabase (required for sign-in) ---
# Use the same Supabase project as the Dari API because the managed service
# exchanges Supabase sessions with DARI_API_BASE_URL.
SUPABASE_URL=https://yfvkbiteydpnffwozqhe.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_7jjhnXR4l2hBJKyCQkGs3g_Tb0AR71p

# --- Hosted Dari agents (required for real managed runs) ---
DARI_API_KEY=
MANAGED_TESTER_AGENT_ID=
MANAGED_EDITOR_AGENT_ID=

# --- Service secrets (required outside placeholder local development) ---
DARI_DOCS_SECRET_ENCRYPTION_KEY=

# --- Host ports (optional) ---
# Leave these blank or unset to let Docker choose open localhost ports.
# Set one only when you need a stable port, e.g. WEB_HOST_PORT=<port>.
API_HOST_PORT=
WEB_HOST_PORT=
POSTGRES_HOST_PORT=

# --- Vite (optional) ---
# Comma-separated hostnames allowed by the Vite dev server.
# VITE_ALLOWED_HOSTS=

# --- Optional ---
DARI_API_BASE_URL=https://dev-api.dari.dev
# PUBLIC_BASE_URL=                           # only needed for Stripe callback URLs
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
